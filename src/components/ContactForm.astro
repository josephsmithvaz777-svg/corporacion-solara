---
const formId = '3VTgUQvgq6kWloJvkV8c';
const formSrc = `https://links.flowincrm.com/widget/form/${formId}`;
const formHeight = 825;
---

<section class="lead" id="contacto" aria-label="Formulario de contacto">
  <div class="lead__panel">
    <div class="lead__badge">LOTES</div>

    <div class="lead__embed">
      <iframe
        src={formSrc}
        style={`width:100%;height:${formHeight}px;border:none;border-radius:8px`}
        id={`inline-${formId}`}
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="Formulario"
        data-height={String(formHeight)}
        data-layout-iframe-id={`inline-${formId}`}
        data-form-id={formId}
        title="Formulario de contacto Solara"
        loading="lazy"
      >
      </iframe>
    </div>
  </div>
</section>

<script is:inline src="https://links.flowincrm.com/js/form_embed.js"></script>

<style>
  .lead {
    background: var(--color-white);
    padding: var(--space-4) 1rem var(--space-5);
    scroll-margin-top: 100px;
  }

  .lead__panel {
    position: relative;
    width: 100%;
    max-width: 560px;
    margin-inline: auto;
    background: var(--color-white);
    border: 1px solid rgba(199, 154, 43, 0.25);
    border-radius: var(--radius-card);
    padding: 1.75rem 0.75rem 0.75rem;
    box-shadow: var(--shadow-soft);
  }

  .lead__badge {
    position: absolute;
    top: 0;
    right: 1rem;
    z-index: 2;
    background: var(--gradient-gold);
    color: var(--color-primary);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.35rem 0.65rem;
    border-radius: 0 0 10px 10px;
  }

  .lead__embed {
    width: 100%;
    min-height: 825px;
  }

  .lead__embed iframe {
    display: block;
    width: 100%;
    min-height: 825px;
  }

  @media (min-width: 1024px) {
    .lead {
      background: transparent;
      padding: 0;
      margin: 0;
    }

    .lead__panel {
      margin: 0;
      max-width: none;
      max-height: calc(100vh - var(--nav-height) - 130px);
      overflow: auto;
      padding: 1.5rem 0.55rem 0.55rem;
      box-shadow: var(--shadow-luxury);
      background: var(--color-white);
    }
  }
</style>
