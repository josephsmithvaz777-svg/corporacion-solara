---
import { Icon } from 'astro-icon/components';
import banner from '../assets/banner-referidos.webp';
---

<section class="referidos" id="referidos" aria-labelledby="referidos-title">
  <div class="referidos__stage">
    <img
      class="referidos__banner"
      src={banner.src}
      alt=""
      width={banner.width}
      height={banner.height}
      loading="lazy"
      aria-hidden="true"
    />

    <div class="referidos__card">
      <h2 id="referidos-title">¡Refiere y gana!</h2>
      <p class="referidos__subtitle">Beneficio exclusivo solo para clientes</p>

      <ul class="referidos__list">
        <li>
          <span class="referidos__check" aria-hidden="true">
            <Icon name="lucide:circle-check" size={22} />
          </span>
          <span>Si eres propietario o copropietario de un lote con Solara Corporación, refiere amigos y familiares.</span>
        </li>
        <li>
          <span class="referidos__check" aria-hidden="true">
            <Icon name="lucide:circle-check" size={22} />
          </span>
          <span>Registra sus datos y si compran, podrás ganar una tarjeta de consumo.</span>
        </li>
        <li>
          <span class="referidos__check" aria-hidden="true">
            <Icon name="lucide:circle-check" size={22} />
          </span>
          <span>A más referidos, más opciones de ganar.</span>
        </li>
      </ul>

      <a class="referidos__cta" href="#contacto">
        Más información
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .referidos {
    background: var(--color-surface);
    padding: 0;
  }

  .referidos__stage {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--color-primary-dark);
    padding-bottom: 1.75rem;
  }

  /* Móvil: crop arriba (sin estirar), fondo verde debajo, card encima */
  .referidos__banner {
    width: 100%;
    height: clamp(230px, 48vw, 300px);
    display: block;
    object-fit: cover;
    object-position: center top;
  }

  .referidos__card {
    position: relative;
    z-index: 2;
    width: calc(100% - 2rem);
    max-width: 420px;
    margin: -2.75rem auto 0;
    background: var(--color-white);
    border-radius: 36px;
    padding: 1.75rem 1.5rem 1.6rem;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.16);
  }

  .referidos__card h2 {
    margin: 0;
    font-family: var(--font-family);
    font-size: clamp(1.55rem, 3vw, 1.9rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-primary);
  }

  .referidos__subtitle {
    margin: 0.35rem 0 1.25rem;
    color: var(--color-primary-mid);
    font-size: 0.98rem;
  }

  .referidos__list {
    list-style: none;
    margin: 0 0 1.4rem;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }

  .referidos__list li {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    color: var(--color-primary);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .referidos__check {
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 0.1rem;
  }

  .referidos__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 48px;
    padding: 0.7rem 1.35rem;
    border-radius: var(--radius-pill);
    background: var(--gradient-gold);
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.95rem;
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .referidos__cta:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-soft);
  }

  @media (min-width: 768px) {
    .referidos__stage {
      padding-bottom: 0;
    }

    .referidos__banner {
      height: auto;
      aspect-ratio: 1943 / 535;
      object-position: center;
    }

    .referidos__card {
      position: absolute;
      top: 50%;
      left: clamp(1rem, 3.5vw, 2.75rem);
      bottom: auto;
      margin: 0;
      translate: 0 -50%;
      width: min(34%, 340px);
      max-width: none;
      max-height: calc(100% - 2.5rem);
      overflow: auto;
      border-radius: 28px;
      padding: 1.15rem 1.15rem 1.2rem;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);
    }

    .referidos__card h2 {
      font-size: 1.35rem;
    }

    .referidos__subtitle {
      margin: 0.25rem 0 0.85rem;
      font-size: 0.82rem;
    }

    .referidos__list {
      gap: 0.55rem;
      margin-bottom: 1rem;
    }

    .referidos__list li {
      font-size: 0.78rem;
      line-height: 1.35;
      gap: 0.5rem;
    }

    .referidos__check :global(svg) {
      width: 18px;
      height: 18px;
    }

    .referidos__cta {
      min-height: 40px;
      padding: 0.5rem 1.05rem;
      font-size: 0.85rem;
    }
  }

  @media (min-width: 1100px) {
    .referidos__card {
      width: min(30%, 360px);
      left: clamp(1.5rem, 4vw, 3.25rem);
      padding: 1.35rem 1.35rem 1.3rem;
      border-radius: 32px;
    }

    .referidos__card h2 {
      font-size: 1.45rem;
    }

    .referidos__list li {
      font-size: 0.84rem;
    }
  }

  @media (min-width: 1400px) {
    .referidos__card {
      width: 380px;
    }
  }
</style>
