---
import { projects, ctas } from '../data/site';
import imgMallViru from '../assets/projects/img-card-mall-viru.webp';
import imgOasis from '../assets/projects/img-card-oasis.webp';
import imgCostaVerde from '../assets/projects/img-card-costa-verde.webp';

const projectImages = {
  'mall-viru': imgMallViru,
  'oasis-residencial-ii': imgOasis,
  'costa-verde': imgCostaVerde,
} as const;

const cards = projects.map((project) => ({
  ...project,
  src: projectImages[project.slug as keyof typeof projectImages],
}));
---

<section class="section projects" id="proyectos" aria-labelledby="proyectos-title">
  <div class="container">
    <p class="section__eyebrow">Nuestros proyectos</p>
    <h2 class="section__title" id="proyectos-title">Desarrollo con visión de futuro</h2>
    <p class="section__lead">
      Cada proyecto tiene identidad propia y mantiene la coherencia de Solara Corporación.
    </p>

    <div class="projects__list">
      {
        cards.map((project) => (
          <article class:list={['project', { 'project--featured': project.featured }]}>
            <div class="project__media">
              <img
                src={project.src.src}
                alt={`Proyecto ${project.name}`}
                width={project.src.width}
                height={project.src.height}
                loading="lazy"
              />
            </div>
            <div class="project__body">
              <p class="project__type">{project.type}</p>
              <h3>{project.name}</h3>
              <p class="project__location">{project.location}</p>
              <p class="project__summary">{project.summary}</p>
              <ul>
                {project.highlights.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <a class="btn btn--primary" href="#contacto">{ctas.quote}</a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects {
    background: var(--color-bg);
  }

  .projects__list {
    display: grid;
    gap: 1.5rem;
    margin-top: var(--space-5);
  }

  .project {
    display: grid;
    background: var(--color-surface);
    border: 1px solid rgba(199, 154, 43, 0.2);
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    transition:
      transform var(--transition),
      box-shadow var(--transition);
  }

  .project:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-medium);
  }

  .project__media {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--color-primary-dark);
  }

  .project__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.5s ease;
  }

  .project:hover .project__media img {
    transform: scale(1.04);
  }

  .project__body {
    padding: 1.35rem 1.35rem 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .project__type {
    color: var(--color-gold);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.4rem;
  }

  .project h3 {
    font-size: 1.55rem;
    margin: 0 0 0.3rem;
    color: var(--color-primary);
  }

  .project__location {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    margin: 0 0 0.85rem;
  }

  .project__summary {
    margin: 0 0 0.85rem;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .project ul {
    margin: 0 0 1.25rem;
    padding-left: 1.1rem;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    flex: 1;
  }

  .project li + li {
    margin-top: 0.3rem;
  }

  .project .btn {
    align-self: flex-start;
  }

  @media (min-width: 900px) {
    .project {
      grid-template-columns: minmax(200px, 0.85fr) minmax(0, 1.15fr);
      align-items: stretch;
      min-height: 0;
    }

    .project--featured {
      grid-template-columns: minmax(220px, 0.9fr) minmax(0, 1.1fr);
    }

    .project__media {
      aspect-ratio: 3 / 4;
      height: auto;
      min-height: 0;
      max-height: 420px;
    }

    .project__body {
      padding: 1.5rem 1.5rem 1.6rem;
      justify-content: center;
    }

    .project h3 {
      font-size: 1.7rem;
    }
  }
</style>
