---
import { benefits } from '../data/site';
---

<section class="section benefits" id="beneficios" aria-labelledby="beneficios-title">
  <div class="container">
    <p class="section__eyebrow">Confianza primero</p>
    <h2 class="section__title" id="beneficios-title">Más que un terreno, una oportunidad</h2>
    <p class="section__lead">
      Ayudamos a personas y emprendedores a invertir en espacios estratégicos con claridad y respaldo.
    </p>

    <div class="benefits__grid">
      {
        benefits.map((item) => (
          <article class="benefit">
            <div class="benefit__icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d="M12 3l7 4v6c0 4-3 7-7 8-4-1-7-4-7-8V7l7-4z" />
              </svg>
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .benefits {
    background: var(--color-surface);
  }

  .benefits__grid {
    display: grid;
    gap: 1.25rem;
    margin-top: var(--space-5);
  }

  .benefit {
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: var(--radius-card);
    padding: var(--space-4);
    box-shadow: var(--shadow-soft);
    transition: transform var(--transition);
  }

  .benefit:hover {
    transform: translateY(-6px);
  }

  .benefit__icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    display: grid;
    place-items: center;
    color: var(--color-gold);
    background: rgba(199, 154, 43, 0.12);
    margin-bottom: 1rem;
  }

  .benefit h3 {
    color: var(--color-white);
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .benefit p {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.95rem;
  }

  @media (min-width: 768px) {
    .benefits__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1100px) {
    .benefits__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
