---
import { ctas, projects } from '../data/site';
---

<section class="section contact" id="contacto" aria-labelledby="contacto-title">
  <div class="container contact__grid">
    <div class="contact__intro">
      <p class="section__eyebrow">Hablemos</p>
      <h2 class="section__title" id="contacto-title">Solicita información</h2>
      <p class="section__lead">
        Completa el formulario y un asesor te contactará. Sin presión: te ayudamos a elegir con claridad.
      </p>
      <ul>
        <li>Agenda una visita</li>
        <li>Cotiza tu lote</li>
        <li>Conoce Mall Virú y más proyectos</li>
      </ul>
    </div>

    <form class="contact__form" method="post" action="#" data-contact-form>
      <p class="contact__steps" aria-hidden="true"><span>1</span><span>2</span></p>
      <h3>Quiero recibir información</h3>

      <div class="contact__row">
        <label>
          <span class="sr-only">Nombre</span>
          <input type="text" name="nombre" placeholder="Nombre*" required autocomplete="given-name" />
        </label>
        <label>
          <span class="sr-only">Apellidos</span>
          <input type="text" name="apellidos" placeholder="Apellidos*" required autocomplete="family-name" />
        </label>
      </div>

      <div class="contact__row">
        <label>
          <span class="sr-only">Documento</span>
          <input type="text" name="documento" placeholder="Nro. de documento" autocomplete="off" />
        </label>
        <label>
          <span class="sr-only">Teléfono</span>
          <input type="tel" name="telefono" placeholder="Teléfono* (+51)" required autocomplete="tel" />
        </label>
      </div>

      <label>
        <span class="sr-only">Correo</span>
        <input type="email" name="email" placeholder="Correo electrónico*" required autocomplete="email" />
      </label>

      <label>
        <span class="sr-only">Proyecto de interés</span>
        <select name="proyecto" required>
          <option value="">Proyecto de interés*</option>
          {projects.map((p) => <option value={p.slug}>{p.name}</option>)}
          <option value="otro">Quiero asesoria general</option>
        </select>
      </label>

      <label class="contact__check">
        <input type="checkbox" name="privacidad" required />
        <span>He leído y acepto el tratamiento de mis datos personales.</span>
      </label>

      <button class="btn btn--on-dark" type="submit">{ctas.primary}</button>
      <p class="contact__note" data-form-note hidden>Gracias. Pronto un asesor te contactará.</p>
    </form>
  </div>
</section>

<style>
  .contact {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .contact :global(.section__title),
  .contact :global(.section__lead) {
    color: var(--color-white);
  }

  .contact :global(.section__lead) {
    opacity: 0.85;
  }

  .contact__grid {
    display: grid;
    gap: var(--space-5);
  }

  .contact__intro ul {
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.65rem;
  }

  .contact__intro li {
    position: relative;
    padding-left: 1.25rem;
    color: rgba(255, 255, 255, 0.86);
  }

  .contact__intro li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-gold);
  }

  .contact__form {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(232, 198, 106, 0.28);
    border-radius: var(--radius-card);
    padding: var(--space-4);
    backdrop-filter: blur(16px);
    display: grid;
    gap: 0.85rem;
  }

  .contact__steps {
    display: flex;
    gap: 0.65rem;
    margin: 0;
  }

  .contact__steps span {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .contact__steps span:first-child {
    background: var(--color-gold);
    color: var(--color-primary);
  }

  .contact__steps span:last-child {
    border: 1px solid rgba(255, 255, 255, 0.45);
    color: var(--color-white);
  }

  .contact__form h3 {
    color: var(--color-white);
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 600;
  }

  .contact__row {
    display: grid;
    gap: 0.85rem;
  }

  .contact__form input,
  .contact__form select {
    width: 100%;
    min-height: 52px;
    border-radius: var(--radius-input);
    border: 1px solid var(--color-gold-soft);
    background: var(--color-white);
    color: var(--color-text);
    padding: 0 1rem;
  }

  .contact__form input:focus,
  .contact__form select:focus {
    outline: 2px solid var(--color-gold);
    outline-offset: 1px;
  }

  .contact__check {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .contact__check input {
    width: auto;
    min-height: auto;
    margin-top: 0.2rem;
  }

  .contact__note {
    color: var(--color-gold-light);
    font-size: 0.95rem;
  }

  @media (min-width: 700px) {
    .contact__row {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 960px) {
    .contact__grid {
      grid-template-columns: 1fr 1.05fr;
      align-items: center;
    }
  }
</style>

<script>
  const form = document.querySelector('[data-contact-form]');
  const note = document.querySelector('[data-form-note]');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (note) note.hidden = false;
    if (form instanceof HTMLFormElement) form.reset();
  });
</script>
