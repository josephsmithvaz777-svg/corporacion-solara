---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Solara Corporación | Lotes e inversión inmobiliaria en Virú',
  description = 'Invierte en lotes residenciales y comerciales en Virú con Solara Corporación. Financiamiento accesible, documentación en regla y proyectos con plusvalía.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Lotes en Virú, Lotes comerciales, Lotes residenciales, Mall Virú, Inversión inmobiliaria, Corporación Solara, La Libertad, Perú" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/favicon.webp" />
    <meta name="theme-color" content="#0D2F28" />
    <link rel="icon" href="/favicon.webp" type="image/webp" />
    <link rel="apple-touch-icon" href="/favicon.webp" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
