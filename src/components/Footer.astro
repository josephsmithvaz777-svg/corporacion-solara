---
import { brand, nav } from '../data/site';
import logoSolara from '../assets/logo-solara-corporacion.webp';
---

<footer class="footer">
  <div class="container footer__grid">
    <div>
      <img src={logoSolara.src} alt={brand.name} width="200" height="52" />
      <p class="footer__legal">Razón social: {brand.legalName}</p>
      <p class="footer__legal">RUC: {brand.ruc}</p>
      <p class="footer__tagline">{brand.tagline}</p>
    </div>

    <div>
      <h3>Navegación</h3>
      <ul>
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3>Proyectos</h3>
      <ul>
        <li><a href="#proyectos">Mall Virú</a></li>
        <li><a href="#proyectos">Oasis Residencial II</a></li>
        <li><a href="#proyectos">Costa Verde</a></li>
      </ul>
    </div>

    <div>
      <h3>Contacto</h3>
      <ul>
        <li><a href="#contacto">Solicitar información</a></li>
        <li><a href="#mapa">Ver ubicación</a></li>
      </ul>
      <p class="footer__region">{brand.region}</p>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>© {new Date().getFullYear()} {brand.name}. Todos los derechos reservados.</p>
      <div>
        <a href="#contacto">Privacidad</a>
        <a href="#contacto">Términos</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary-dark);
    color: rgba(255, 255, 255, 0.88);
    padding-top: var(--space-6);
  }

  .footer__grid {
    display: grid;
    gap: var(--space-4);
    padding-bottom: var(--space-5);
  }

  .footer img {
    height: 52px;
    width: auto;
    margin-bottom: 1rem;
  }

  .footer__legal,
  .footer__tagline,
  .footer__region {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.72);
  }

  .footer__tagline {
    margin-top: 0.85rem;
    max-width: 22rem;
  }

  .footer h3 {
    color: var(--color-gold-light);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.85rem;
  }

  .footer ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }

  .footer a {
    color: rgba(255, 255, 255, 0.84);
    transition: color var(--transition);
  }

  .footer a:hover {
    color: var(--color-gold-light);
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer__bottom-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem 0;
    font-size: 0.82rem;
  }

  .footer__bottom-inner div {
    display: flex;
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .footer__grid {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
    }
  }
</style>
