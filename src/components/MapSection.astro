---
const officeEmbedUrl =
  'https://www.google.com/maps?q=-8.4135827,-78.7522504&hl=es&z=18&output=embed';
---

<section class="section map" id="mapa" aria-labelledby="mapa-title">
  <div class="container map__grid">
    <div>
      <p class="section__eyebrow">Ubicación</p>
      <h2 class="section__title" id="mapa-title">Nuestra oficina</h2>
      <p class="section__lead">
        Visítanos en Corporación Solara. Te atendemos para resolver dudas, cotizar y acompañarte en tu inversión.
      </p>
      <p class="map__address">Corporación Solara · Virú, La Libertad</p>
    </div>

    <div class="map__frame">
      <iframe
        title="Ubicación de la oficina Corporación Solara"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
        src={officeEmbedUrl}
      ></iframe>
    </div>
  </div>
</section>

<style>
  .map {
    background: var(--color-bg);
  }

  .map__grid {
    display: grid;
    gap: var(--space-4);
  }

  .map__address {
    margin: 1.25rem 0 0;
    color: var(--color-primary);
    font-weight: 600;
  }

  .map__frame {
    border-radius: var(--radius-card);
    overflow: hidden;
    min-height: 320px;
    border: 1px solid rgba(199, 154, 43, 0.25);
    box-shadow: var(--shadow-soft);
  }

  .map__frame iframe {
    width: 100%;
    height: 100%;
    min-height: 320px;
    border: 0;
  }

  @media (min-width: 900px) {
    .map__grid {
      grid-template-columns: 0.9fr 1.1fr;
      align-items: stretch;
    }

    .map__frame,
    .map__frame iframe {
      min-height: 420px;
    }
  }
</style>
