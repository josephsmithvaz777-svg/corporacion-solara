---
// Reemplaza el número cuando lo tengas (formato internacional sin +)
const phone = '51999999999';
const message = encodeURIComponent('Hola Solara Corporación, quiero información sobre sus proyectos.');
---

<a
  class="whatsapp"
  href={`https://wa.me/${phone}?text=${message}`}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escribir por WhatsApp"
>
  <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
    <path
      fill="currentColor"
      d="M19.11 17.45c-.28-.14-1.64-.81-1.9-.9-.25-.1-.44-.14-.62.14-.19.28-.71.9-.87 1.08-.16.19-.32.21-.6.07-.28-.14-1.17-.43-2.23-1.37-.82-.73-1.38-1.64-1.54-1.91-.16-.28-.02-.43.12-.57.12-.12.28-.32.42-.48.14-.16.19-.28.28-.46.1-.19.05-.35-.02-.49-.07-.14-.62-1.49-.85-2.04-.22-.53-.45-.46-.62-.46h-.53c-.19 0-.49.07-.74.35-.25.28-.97.95-.97 2.31s.99 2.68 1.13 2.87c.14.19 1.95 2.98 4.72 4.18 1.76.76 2.45.82 3.33.69.51-.08 1.64-.67 1.87-1.32.23-.65.23-1.2.16-1.32-.07-.11-.25-.18-.53-.32z"
    ></path>
    <path
      fill="currentColor"
      d="M16 3C8.83 3 3 8.83 3 16c0 2.28.66 4.4 1.8 6.2L3 29l6.98-1.83A12.9 12.9 0 0 0 16 29c7.17 0 13-5.83 13-13S23.17 3 16 3zm0 23.67c-2.1 0-4.05-.6-5.71-1.64l-.41-.25-4.14 1.09 1.1-4.03-.27-.42A10.6 10.6 0 0 1 5.33 16C5.33 10.12 10.12 5.33 16 5.33S26.67 10.12 26.67 16 21.88 26.67 16 26.67z"
    ></path>
  </svg>
  <span>WhatsApp</span>
</a>

<style>
  .whatsapp {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 52px;
    padding: 0 1rem 0 0.85rem;
    border-radius: var(--radius-pill);
    background: var(--gradient-gold);
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.92rem;
    box-shadow: var(--shadow-medium);
    transition: transform var(--transition), filter var(--transition);
  }

  .whatsapp:hover {
    transform: translateY(-3px);
    filter: brightness(1.06);
  }
</style>
