---
import { brand, nav, ctas } from '../data/site';
import logoSolara from '../assets/logo-solara-corporacion.webp';
---

<header class="header">
  <div class="header__top">
    <div class="container header__top-inner">
      <span>{brand.region}</span>
      <span>RUC {brand.ruc}</span>
    </div>
  </div>

  <div class="header__main">
    <div class="container header__bar">
      <a class="header__logo" href="#inicio" aria-label={brand.name}>
        <img src={logoSolara.src} alt={brand.name} width={logoSolara.width} height={logoSolara.height} />
      </a>

      <nav class="header__nav" aria-label="Principal">
        {nav.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>

      <a class="btn btn--primary header__cta" href="#contacto">{ctas.primary}</a>

      <button class="header__menu" type="button" aria-expanded="false" aria-controls="mobile-nav" data-menu-toggle>
        <span class="sr-only">Abrir menú</span>
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="header__drawer" id="mobile-nav" hidden data-menu-panel>
    <nav aria-label="Móvil">
      {nav.map((item) => (
        <a href={item.href} data-menu-link>{item.label}</a>
      ))}
      <a class="btn btn--primary" href="#contacto" data-menu-link>{ctas.primary}</a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header__top {
    background: var(--color-white);
    color: var(--color-primary);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    border-bottom: 1px solid rgba(13, 47, 40, 0.08);
  }

  .header__top-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.45rem 0;
  }

  .header__main {
    background: var(--color-primary);
    height: var(--nav-height);
    display: flex;
    align-items: center;
  }

  .header__bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    width: min(100% - 2rem, var(--container));
  }

  .header__logo {
    display: flex;
    align-items: center;
    line-height: 0;
  }

  .header__logo img {
    height: 68px;
    width: auto;
    object-fit: contain;
  }

  .header__nav {
    display: none;
    justify-content: center;
    gap: 1.35rem;
  }

  .header__nav a {
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.92rem;
    font-weight: 500;
    transition: color var(--transition);
  }

  .header__nav a:hover {
    color: var(--color-gold-light);
  }

  .header__cta {
    display: none;
    min-height: 48px;
    padding-inline: 1.35rem;
    font-size: 0.92rem;
  }

  .header__menu {
    justify-self: end;
    width: 44px;
    height: 44px;
    border: 1px solid var(--color-gold-soft);
    border-radius: 12px;
    background: transparent;
    display: grid;
    place-content: center;
    gap: 5px;
    cursor: pointer;
  }

  .header__menu span:not(.sr-only) {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--color-gold-light);
  }

  .header__drawer {
    background: var(--color-primary-dark);
    padding: 1.25rem 1rem 1.75rem;
  }

  .header__drawer nav {
    display: grid;
    gap: 0.85rem;
    width: min(100% - 0.5rem, var(--container));
    margin-inline: auto;
  }

  .header__drawer a:not(.btn) {
    color: var(--color-white);
    padding: 0.65rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  @media (min-width: 960px) {
    .header__nav {
      display: flex;
    }

    .header__cta {
      display: inline-flex;
    }

    .header__menu,
    .header__drawer {
      display: none !important;
    }
  }
</style>

<script>
  const toggle = document.querySelector('[data-menu-toggle]');
  const panel = document.querySelector('[data-menu-panel]');
  const links = document.querySelectorAll('[data-menu-link]');

  function closeMenu() {
    if (!toggle || !panel) return;
    panel.hidden = true;
    toggle.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    if (!panel) return;
    const open = panel.hidden;
    panel.hidden = !open;
    toggle.setAttribute('aria-expanded', String(open));
  });

  links.forEach((link) => link.addEventListener('click', closeMenu));
</script>
