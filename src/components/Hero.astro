---
import { brand, ctas } from '../data/site';
---

<section class="hero" id="inicio" aria-label="Inicio">
  <div class="hero__media" aria-hidden="true">
    <img src="/images/hero-mall-viru.png" alt="" class="hero__image" />
    <div class="hero__overlay"></div>
  </div>

  <div class="container hero__content">
    <p class="hero__brand reveal">{brand.name}</p>
    <h1 class="hero__title reveal reveal-delay-1">
      Invierte hoy.<br />
      <span>Crece mañana.</span>
    </h1>
    <p class="hero__subtitle reveal reveal-delay-2">
      {brand.tagline}. Lotes residenciales y comerciales en Virú con proyectos pensados para patrimonio y negocio.
    </p>
    <div class="hero__actions reveal reveal-delay-2">
      <a class="btn btn--primary" href="#contacto">{ctas.visit}</a>
      <a class="btn btn--secondary-light" href="#proyectos">Conoce el proyecto</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(92vh, 820px);
    display: grid;
    align-items: end;
    color: var(--color-white);
    overflow: hidden;
  }

  .hero__media {
    position: absolute;
    inset: 0;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transform: scale(1.04);
    animation: fade-in 1.2s ease both;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding: 7rem 0 5rem;
    max-width: 46rem;
  }

  .hero__brand {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
    color: var(--color-white);
  }

  .hero__title {
    font-size: clamp(2.75rem, 7vw, 5rem);
    color: var(--color-white);
    margin-bottom: 1.25rem;
  }

  .hero__title span {
    color: var(--color-gold-light);
  }

  .hero__subtitle {
    font-size: 1.05rem;
    max-width: 34rem;
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 2rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  @media (min-width: 900px) {
    .hero {
      align-items: center;
    }

    .hero__content {
      padding: 8rem 0 6rem;
    }
  }
</style>
