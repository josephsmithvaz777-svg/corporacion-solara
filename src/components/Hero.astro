---
import { brand } from '../data/site';
import banner1 from '../assets/banner-home-NEW-1.webp';
import banner2 from '../assets/banner-home-NEW-2.webp';
import banner3 from '../assets/banner-home-NEW-3.webp';
import bannerMovil1 from '../assets/banner-movil-1.webp';
import bannerMovil2 from '../assets/banner-movil-2.webp';
import bannerMovil3 from '../assets/banner-movil-3.webp';

const slides = [
  { image: banner1, mobile: bannerMovil1, label: 'Mall Virú' },
  { image: banner2, mobile: bannerMovil2, label: 'Lotes comerciales' },
  { image: banner3, mobile: bannerMovil3, label: 'Lotes residenciales' },
];
---

<section class="hero" id="inicio" aria-roledescription="carrusel" aria-label="Banner principal">
  <h1 class="sr-only">{brand.name}</h1>
  <div class="hero__frame">
    <div class="hero__viewport" data-hero-carousel>
      {
        slides.map((slide, index) => (
          <article
            class:list={['hero__slide', { 'is-active': index === 0 }]}
            data-slide
            aria-hidden={index === 0 ? 'false' : 'true'}
            aria-label={slide.label}
          >
            <img
              src={slide.image.src}
              alt={slide.label}
              class="hero__image hero__image--desktop"
              width="1942"
              height="534"
              loading={index === 0 ? 'eager' : 'lazy'}
              fetchpriority={index === 0 ? 'high' : 'auto'}
            />
            <img
              src={slide.mobile.src}
              alt={slide.label}
              class="hero__image hero__image--mobile"
              width="521"
              height="553"
              loading={index === 0 ? 'eager' : 'lazy'}
              fetchpriority={index === 0 ? 'high' : 'auto'}
            />
          </article>
        ))
      }

      <button class="hero__nav hero__nav--prev" type="button" data-hero-prev aria-label="Banner anterior">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 5L8 12l7 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>
      <button class="hero__nav hero__nav--next" type="button" data-hero-next aria-label="Banner siguiente">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <div class="hero__dots" role="tablist" aria-label="Seleccionar banner">
        {
          slides.map((_, index) => (
            <button
              class:list={['hero__dot', { 'is-active': index === 0 }]}
              type="button"
              role="tab"
              aria-label={`Ir al banner ${index + 1}`}
              aria-selected={index === 0 ? 'true' : 'false'}
              data-hero-dot={index}
            ></button>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-primary-dark);
  }

  .hero__frame {
    width: 100%;
    max-width: 1942px;
    margin-inline: auto;
  }

  /* Móvil: banners rectangulares (banner-movil) */
  .hero__viewport {
    position: relative;
    width: 100%;
    aspect-ratio: 521 / 553;
    overflow: hidden;
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
  }

  .hero__viewport.is-dragging {
    cursor: grabbing;
  }

  /* Tablet y escritorio: mismo banner panorámico */
  @media (min-width: 768px) {
    .hero__viewport {
      aspect-ratio: 1942 / 534;
    }
  }

  @media (min-width: 1942px) {
    .hero__viewport {
      height: 534px;
      aspect-ratio: auto;
    }
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.55s ease,
      visibility 0.55s ease;
  }

  .hero__slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    pointer-events: none;
  }

  /* Solo móvil: banner-movil-1/2/3 */
  .hero__image--desktop {
    display: none;
  }

  .hero__image--mobile {
    display: block;
  }

  @media (min-width: 768px) {
    .hero__image--desktop {
      display: block;
    }

    .hero__image--mobile {
      display: none;
    }
  }

  .hero__nav {
    position: absolute;
    top: 50%;
    z-index: 4;
    translate: 0 -50%;
    width: 36px;
    height: 36px;
    border: 0;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.18);
    color: var(--color-white);
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: background var(--transition);
  }

  .hero__nav:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .hero__nav--prev {
    left: 0.75rem;
  }

  .hero__nav--next {
    right: 0.75rem;
  }

  .hero__dots {
    position: absolute;
    left: 50%;
    bottom: 0.75rem;
    z-index: 4;
    translate: -50% 0;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 0;
    padding: 0;
    background: rgba(255, 255, 255, 0.45);
    cursor: pointer;
    transition:
      background var(--transition),
      width var(--transition);
  }

  .hero__dot.is-active {
    width: 22px;
    border-radius: 999px;
    background: var(--color-gold-light);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__slide,
    .hero__dot,
    .hero__nav {
      transition: none;
    }
  }
</style>

<script>
  const root = document.querySelector('[data-hero-carousel]');
  if (root instanceof HTMLElement) {
    const slides = Array.from(root.querySelectorAll('[data-slide]'));
    const dots = Array.from(root.querySelectorAll('[data-hero-dot]'));
    const prev = root.querySelector('[data-hero-prev]');
    const next = root.querySelector('[data-hero-next]');
    let index = 0;
    let timer;
    let dragging = false;
    let dragStartX = 0;
    let dragDelta = 0;

    const show = (nextIndex) => {
      index = (nextIndex + slides.length) % slides.length;
      slides.forEach((slide, i) => {
        const active = i === index;
        slide.classList.toggle('is-active', active);
        slide.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
      dots.forEach((dot, i) => {
        const active = i === index;
        dot.classList.toggle('is-active', active);
        dot.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    };

    const start = () => {
      stop();
      timer = window.setInterval(() => show(index + 1), 6000);
    };

    const stop = () => {
      if (timer) window.clearInterval(timer);
    };

    const onPointerDown = (event) => {
      const target = event.target;
      if (target instanceof Element && target.closest('.hero__nav, .hero__dot, .hero__dots')) return;
      if (event.pointerType === 'mouse' && event.button !== 0) return;
      dragging = true;
      dragStartX = event.clientX;
      dragDelta = 0;
      root.classList.add('is-dragging');
      root.setPointerCapture(event.pointerId);
      stop();
    };

    const onPointerMove = (event) => {
      if (!dragging) return;
      dragDelta = event.clientX - dragStartX;
    };

    const onPointerUp = (event) => {
      if (!dragging) return;
      dragging = false;
      root.classList.remove('is-dragging');
      try {
        root.releasePointerCapture(event.pointerId);
      } catch {
        /* ignore */
      }

      const threshold = 50;
      if (dragDelta > threshold) show(index - 1);
      else if (dragDelta < -threshold) show(index + 1);
      start();
    };

    root.addEventListener('pointerdown', onPointerDown);
    root.addEventListener('pointermove', onPointerMove);
    root.addEventListener('pointerup', onPointerUp);
    root.addEventListener('pointercancel', onPointerUp);

    prev?.addEventListener('click', () => {
      show(index - 1);
      start();
    });
    next?.addEventListener('click', () => {
      show(index + 1);
      start();
    });
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const value = Number(dot.getAttribute('data-hero-dot') || 0);
        show(value);
        start();
      });
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', () => {
      if (!dragging) start();
    });
    start();
  }
</script>
