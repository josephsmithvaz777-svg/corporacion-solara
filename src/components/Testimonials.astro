---
import { testimonials } from '../data/site';
import img1 from '../assets/testimonios/testimonios-1.webp';
import img2 from '../assets/testimonios/testimonios-2.webp';
import img3 from '../assets/testimonios/testimonios-3.webp';
import img4 from '../assets/testimonios/testimonios-4.webp';
import img5 from '../assets/testimonios/testimonios-5.webp';
import img6 from '../assets/testimonios/testimonios-6.webp';

const images = {
  'testimonios-1': img1,
  'testimonios-2': img2,
  'testimonios-3': img3,
  'testimonios-4': img4,
  'testimonios-5': img5,
  'testimonios-6': img6,
} as const;

const slides = testimonials.map((item) => ({
  ...item,
  src: images[item.image as keyof typeof images],
}));
---

<section class="section testimonials" id="testimonios" aria-labelledby="testimonios-title">
  <div class="container">
    <p class="section__eyebrow">Historias reales</p>
    <h2 class="section__title" id="testimonios-title">Quienes confían en Solara</h2>
    <p class="section__lead">Inversión con cercanía, seguridad y mirada de largo plazo.</p>

    <div class="testimonials__carousel" data-testimonials-carousel style="--per-view: 1; --gap: 1.15rem;">
      <button class="testimonials__nav testimonials__nav--prev" type="button" data-testimonials-prev aria-label="Anterior">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 5L8 12l7 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>
      <button class="testimonials__nav testimonials__nav--next" type="button" data-testimonials-next aria-label="Siguiente">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <div class="testimonials__viewport">
        <div class="testimonials__track" data-testimonials-track>
          {
            slides.map((item, index) => (
              <article class="testimonial" data-testimonial-slide aria-roledescription="slide" aria-label={`${index + 1} de ${slides.length}`}>
                <div class="testimonial__media">
                  <img
                    src={item.src.src}
                    alt={`Testimonio de ${item.name}`}
                    width={item.src.width}
                    height={item.src.height}
                    loading={index < 3 ? 'eager' : 'lazy'}
                  />
                </div>
                <div class="testimonial__card">
                  <p class="testimonial__focus">“{item.focus}”</p>
                  <p class="testimonial__quote">{item.quote}</p>
                  <div class="testimonial__meta">
                    <strong>{item.name}</strong>
                    <span>{item.project}</span>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <div class="testimonials__dots" role="tablist" aria-label="Seleccionar testimonio" data-testimonials-dots></div>
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--color-bg);
  }

  .testimonials__carousel {
    position: relative;
    margin-top: var(--space-5);
    padding-inline: 0.25rem;
  }

  .testimonials__viewport {
    overflow: hidden;
    padding-bottom: 0.25rem;
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
  }

  .testimonials__viewport.is-dragging {
    cursor: grabbing;
  }

  .testimonials__viewport.is-dragging .testimonials__track {
    transition: none;
  }

  .testimonials__track {
    display: flex;
    gap: var(--gap);
    transition: transform 0.45s ease;
    will-change: transform;
  }

  .testimonial {
    flex: 0 0 calc((100% - (var(--per-view) - 1) * var(--gap)) / var(--per-view));
    min-width: 0;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .testimonial__media {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 18px;
    overflow: hidden;
    background: var(--color-primary-dark);
  }

  .testimonial__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    pointer-events: none;
  }

  /* Caja blanca superpuesta abajo, como la referencia */
  .testimonial__card {
    position: relative;
    z-index: 1;
    width: calc(100% - 1.5rem);
    margin: -4.5rem auto 0;
    background: var(--color-white);
    border-radius: 14px;
    padding: 1.15rem 1rem 1.1rem;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.12);
    text-align: center;
  }

  .testimonial__focus {
    font-family: var(--font-family);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-primary);
    margin: 0 0 0.55rem;
  }

  .testimonial__quote {
    color: var(--color-primary-mid);
    font-size: 0.84rem;
    line-height: 1.45;
    margin: 0 0 0.9rem;
  }

  .testimonial__meta {
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .testimonial__meta strong {
    display: block;
    text-align: left;
    color: var(--color-primary);
    font-weight: 700;
  }

  .testimonial__meta span {
    display: block;
    text-align: right;
    color: var(--color-primary);
    font-weight: 400;
  }

  .testimonials__nav {
    position: absolute;
    top: 38%;
    z-index: 5;
    translate: 0 -50%;
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--color-white);
    color: var(--color-primary);
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.14);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .testimonials__nav:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }

  .testimonials__nav--prev {
    left: -0.15rem;
  }

  .testimonials__nav--next {
    right: -0.15rem;
  }

  .testimonials__dots {
    display: flex;
    justify-content: center;
    gap: 0.45rem;
    margin-top: 1.35rem;
  }

  .testimonials__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 0;
    padding: 0;
    background: rgba(13, 47, 40, 0.25);
    cursor: pointer;
    transition:
      background var(--transition),
      width var(--transition);
  }

  .testimonials__dot.is-active {
    width: 22px;
    border-radius: 999px;
    background: var(--color-gold);
  }

  @media (min-width: 640px) {
    .testimonial__card {
      width: calc(100% - 1.75rem);
      margin-top: -5rem;
      padding: 1.2rem 1.1rem 1.15rem;
    }

    .testimonial__focus {
      font-size: 1.1rem;
    }
  }

  @media (min-width: 900px) {
    .testimonials__carousel {
      padding-inline: 0.5rem;
    }

    .testimonials__nav--prev {
      left: -0.35rem;
    }

    .testimonials__nav--next {
      right: -0.35rem;
    }

    .testimonial__media {
      border-radius: 20px;
    }

    .testimonial__card {
      margin-top: -5.5rem;
      padding: 1.25rem 1.15rem 1.2rem;
    }

    .testimonial__focus {
      font-size: 1.12rem;
    }

    .testimonial__quote {
      font-size: 0.86rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonials__track {
      transition: none;
    }
  }
</style>

<script>
  const root = document.querySelector('[data-testimonials-carousel]');
  const track = document.querySelector('[data-testimonials-track]');
  const viewport = root?.querySelector('.testimonials__viewport');
  const prev = document.querySelector('[data-testimonials-prev]');
  const next = document.querySelector('[data-testimonials-next]');
  const dotsWrap = document.querySelector('[data-testimonials-dots]');
  const slides = Array.from(document.querySelectorAll('[data-testimonial-slide]'));

  if (
    root instanceof HTMLElement &&
    track instanceof HTMLElement &&
    viewport instanceof HTMLElement &&
    slides.length
  ) {
    let index = 0;
    let timer;
    let dots = [];
    let dragStartX = 0;
    let dragDelta = 0;
    let dragging = false;
    let baseOffset = 0;

    const gap = () => {
      const raw = getComputedStyle(root).getPropertyValue('--gap').trim() || '1.15rem';
      const probe = document.createElement('div');
      probe.style.width = raw;
      document.body.appendChild(probe);
      const value = probe.getBoundingClientRect().width;
      probe.remove();
      return value || 18;
    };

    const getPerView = () => {
      if (window.matchMedia('(min-width: 900px)').matches) return 3;
      if (window.matchMedia('(min-width: 640px)').matches) return 2;
      return 1;
    };

    const maxIndex = () => Math.max(0, slides.length - getPerView());

    const stepSize = () => slides[0].getBoundingClientRect().width + gap();

    const offsetFor = (i) => i * stepSize();

    const buildDots = () => {
      if (!(dotsWrap instanceof HTMLElement)) return;
      const total = maxIndex() + 1;
      dotsWrap.innerHTML = '';
      for (let i = 0; i < total; i += 1) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'testimonials__dot' + (i === index ? ' is-active' : '');
        btn.setAttribute('role', 'tab');
        btn.setAttribute('aria-label', `Ir al grupo ${i + 1}`);
        btn.setAttribute('aria-selected', i === index ? 'true' : 'false');
        btn.addEventListener('click', () => {
          show(i);
          start();
        });
        dotsWrap.appendChild(btn);
      }
      dots = Array.from(dotsWrap.querySelectorAll('.testimonials__dot'));
    };

    const syncDots = () => {
      dots.forEach((dot, i) => {
        const active = i === index;
        dot.classList.toggle('is-active', active);
        dot.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    };

    const show = (nextIndex, animate = true) => {
      const perView = getPerView();
      root.style.setProperty('--per-view', String(perView));
      const max = maxIndex();
      index = ((nextIndex % (max + 1)) + (max + 1)) % (max + 1);
      if (!animate) track.style.transition = 'none';
      track.style.transform = `translateX(-${offsetFor(index)}px)`;
      if (!animate) {
        track.offsetHeight;
        track.style.transition = '';
      }
      syncDots();
    };

    const start = () => {
      stop();
      timer = window.setInterval(() => show(index + 1), 6500);
    };

    const stop = () => {
      if (timer) window.clearInterval(timer);
    };

    const refresh = () => {
      buildDots();
      show(Math.min(index, maxIndex()), false);
    };

    const onPointerDown = (event) => {
      const target = event.target;
      if (target instanceof Element && target.closest('.testimonials__nav, .testimonials__dot, .testimonials__dots')) {
        return;
      }
      if (event.pointerType === 'mouse' && event.button !== 0) return;
      dragging = true;
      dragStartX = event.clientX;
      dragDelta = 0;
      baseOffset = offsetFor(index);
      viewport.classList.add('is-dragging');
      viewport.setPointerCapture(event.pointerId);
      stop();
    };

    const onPointerMove = (event) => {
      if (!dragging) return;
      dragDelta = event.clientX - dragStartX;
      track.style.transform = `translateX(${-baseOffset + dragDelta}px)`;
    };

    const onPointerUp = (event) => {
      if (!dragging) return;
      dragging = false;
      viewport.classList.remove('is-dragging');
      try {
        viewport.releasePointerCapture(event.pointerId);
      } catch {
        /* ignore */
      }

      const threshold = Math.min(80, stepSize() * 0.2);
      if (dragDelta > threshold) show(index - 1);
      else if (dragDelta < -threshold) show(index + 1);
      else show(index);
      start();
    };

    viewport.addEventListener('pointerdown', onPointerDown, { capture: true });
    viewport.addEventListener('pointermove', onPointerMove, { capture: true });
    viewport.addEventListener('pointerup', onPointerUp, { capture: true });
    viewport.addEventListener('pointercancel', onPointerUp, { capture: true });

    prev?.addEventListener('click', () => {
      show(index - 1);
      start();
    });
    next?.addEventListener('click', () => {
      show(index + 1);
      start();
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', () => {
      if (!dragging) start();
    });
    window.addEventListener('resize', refresh);

    refresh();
    start();
  }
</script>
